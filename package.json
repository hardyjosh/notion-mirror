{
  "name": "notion-mirror",
  "version": "1.0.0",
  "description": "Mirror Notion workspaces to local markdown files with incremental sync",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "notion-mirror": "src/index.js"
  },
  "scripts": {
    "sync": "node src/index.js sync",
    "sync:full": "node src/index.js sync --full"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.0",
    "notion-to-md": "^3.1.0"
  }
}
